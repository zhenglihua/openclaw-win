<Page x:Class="OpenClawWin.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:OpenClawWin.Views"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="800"
      Title="设置">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0"
                   Text="设置"
                   FontSize="28"
                   FontWeight="SemiBold"
                   Margin="0,0,0,24"/>

        <!-- 设置内容 -->
        <ScrollViewer Grid.Row="1">
            <StackPanel>
                <!-- 基本设置 -->
                <ui:Card Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="基本设置"
                                  FontWeight="SemiBold"
                                  FontSize="16"
                                  Margin="0,0,0,16"/>

                        <TextBlock Text="网关端口" Margin="0,0,0,8"/>
                        <ui:NumberBox Value="{Binding GatewayPort, Mode=TwoWay}"
                                     Minimum="1024"
                                     Maximum="65535"
                                     Width="200"
                                     HorizontalAlignment="Left"/>

                        <TextBlock Text="工作区路径" Margin="0,16,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Grid.Column="0"
                                       Text="{Binding WorkspacePath, Mode=TwoWay}"
                                       PlaceholderText="默认: 用户主目录"/>
                            <ui:Button Grid.Column="1"
                                      Content="浏览..."
                                      Click="BrowseWorkspace_Click"
                                      Margin="8,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <!-- 启动设置 -->
                <ui:Card Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="启动设置"
                                  FontWeight="SemiBold"
                                  FontSize="16"
                                  Margin="0,0,0,16"/>

                        <CheckBox Content="开机自动启动"
                                 IsChecked="{Binding AutoStartWithWindows, Mode=TwoWay}"
                                 Margin="0,0,0,8"/>

                        <CheckBox Content="启动时最小化"
                                 IsChecked="{Binding StartMinimized, Mode=TwoWay}"
                                 Margin="0,0,0,8"/>

                        <CheckBox Content="关闭时最小化到托盘"
                                 IsChecked="{Binding MinimizeToTray, Mode=TwoWay}"/>
                    </StackPanel>
                </ui:Card>

                <!-- 更新设置 -->
                <ui:Card Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="更新设置"
                                  FontWeight="SemiBold"
                                  FontSize="16"
                                  Margin="0,0,0,16"/>

                        <CheckBox Content="自动检查更新"
                                 IsChecked="{Binding AutoCheckUpdates, Mode=TwoWay}"
                                 Margin="0,0,0,8"/>

                        <TextBlock Text="日志级别" Margin="0,8,0,8"/>
                        <ComboBox SelectedItem="{Binding LogLevel, Mode=TwoWay}" Width="200" HorizontalAlignment="Left">
                            <ComboBoxItem Content="Debug"/>
                            <ComboBoxItem Content="Information"/>
                            <ComboBoxItem Content="Warning"/>
                            <ComboBoxItem Content="Error"/>
                        </ComboBox>
                    </StackPanel>
                </ui:Card>

                <!-- 关于 -->
                <ui:Card>
                    <StackPanel>
                        <TextBlock Text="关于"
                                  FontWeight="SemiBold"
                                  FontSize="16"
                                  Margin="0,0,0,16"/>

                        <TextBlock Text="OpenClaw Manager v1.0.0"/>
                        <TextBlock Text="OpenClaw Windows管理工具"
                                  Foreground="Gray"
                                  Margin="0,4,0,0"/>
                    </StackPanel>
                </ui:Card>
            </StackPanel>
        </ScrollViewer>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="2"
                   Orientation="Horizontal"
                   HorizontalAlignment="Right"
                   Margin="0,24,0,0">
            <ui:Button Content="还原默认设置"
                      Click="ResetDefaults_Click"
                      Margin="0,0,8,0"/>

            <ui:Button Content="保存设置"
                      Appearance="Primary"
                      Click="SaveSettings_Click"/>
        </StackPanel>
    </Grid>
</Page>
